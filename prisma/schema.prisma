generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  savedColleges SavedCollege[]
}

model SavedCollege {
  id        String @id @default(cuid())
  userId    String
  collegeId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
}
